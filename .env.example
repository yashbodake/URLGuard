# URLGuard Environment Variables

# Path to the trained model artifact
MODEL_PATH=data/model/rf_model.joblib

# Risk score threshold (0.0–1.0) — below = LEGITIMATE, above = PHISHING
RISK_THRESHOLD=0.4

# Maximum number of URLs allowed in a batch prediction request
MAX_BATCH_SIZE=100

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
